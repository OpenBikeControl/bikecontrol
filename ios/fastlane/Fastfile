# Fastlane configuration for the Apple App Store listing (iOS).
#
# Manages the localized App Store metadata (name, subtitle, description,
# keywords, ...). The listing text lives in the private `prop` submodule under
# prop/store_metadata/ios/<locale>/ so it is not exposed in the public repo.
# Authentication uses an App Store Connect API key (the same key/issuer/.p8 the
# build workflow uses).

default_platform(:ios)

# fastlane chdir's into the fastlane/ folder before running a lane, so relative
# paths resolve against ios/fastlane/. Anchor everything at the repo root
# instead (GITHUB_WORKSPACE in CI; two levels up from this file locally).
ROOT           = ENV["GITHUB_WORKSPACE"] || File.expand_path("../..", __dir__)
APP_IDENTIFIER = "de.jonasbark.swiftcontrol.darwin"
METADATA       = File.join(ROOT, "prop/store_metadata/ios")   # private submodule
SCREENSHOTS    = File.join(ROOT, "ios/fastlane/screenshots")
API_KEY_JSON   = File.join(ROOT, "ios/fastlane/asc_api_key.json")

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["APPSTORE_API_KEY"],            # the AuthKey id, e.g. "ABCD1234XY"
    issuer_id: ENV["APPSTORE_API_ISSUER_ID"],
    key_filepath: ENV["APPSTORE_API_KEY_PATH"] ||
      File.join(ROOT, "private_keys/AuthKey_#{ENV['APPSTORE_API_KEY']}.p8"),
    in_house: false,
  )
end

platform :ios do
  desc "Upload the localized App Store listing texts & screenshots (no binary)"
  lane :upload_metadata do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      metadata_path: METADATA,
      screenshots_path: SCREENSHOTS,
      skip_binary_upload: true,
      # Screenshots are prepared by scripts/prepare_store_screenshots.sh.
      skip_screenshots: false,
      overwrite_screenshots: true,
      skip_app_version_update: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Download the current App Store listing into prop/store_metadata/ios"
  lane :download_metadata do
    require "json"
    key = asc_api_key
    File.write(API_KEY_JSON, JSON.pretty_generate(key))
    begin
      sh(
        "bundle", "exec", "fastlane", "deliver", "download_metadata",
        "--api_key_path", API_KEY_JSON,
        "--app_identifier", APP_IDENTIFIER,
        "--metadata_path", METADATA,
        "--force", "true",
      )
    ensure
      File.delete(API_KEY_JSON) if File.exist?(API_KEY_JSON)
    end
  end
end
